# CareerForge AI - Backend Environment Variables
# Copy to .env and fill in values

# Application
APP_NAME=CareerForge AI
DEBUG=true

# Database (SQLite for development)
DATABASE_URL=sqlite+aiosqlite:///./careerforge.db
DATABASE_URL_ASYNC=sqlite+aiosqlite:///./careerforge.db

# PostgreSQL (for production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/careerforge
# DATABASE_URL_ASYNC=postgresql+asyncpg://user:password@localhost:5432/careerforge

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.7

# Security (change in production)
SECRET_KEY=your-secret-key-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# AWS (for S3 file uploads in production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=careerforge-uploads

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]